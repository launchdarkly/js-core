{
  "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020"],
        "module": "ES2020",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "moduleResolution": "node",
    "outDir": "dist",
    "sourceMap": true,
    "skipLibCheck": true
  },
  "exclude": ["**/*.test.ts", "dist", "node_modules"]
}
