{
  "name": "@launchdarkly/shopify-oxygen-sdk",
  "version": "0.1.15",
  "description": "LaunchDarkly Server-Side SDK for Shopify Oxygen Runtime",
  "homepage": "https://github.com/launchdarkly/js-core/tree/main/packages/sdk/shopify-oxygen",
  "repository": {
    "type": "git",
    "url": "https://github.com/launchdarkly/js-core.git"
  },
  "license": "Apache-2.0",
  "keywords": [
    "launchdarkly",
    "shopify",
    "oxygen",
    "edge",
    "worker"
  ],
  "type": "module",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "require": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "tsw": "yarn tsc --watch",
    "start": "rimraf dist && yarn tsw",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules --no-warnings\" jest --ci --runInBand",
    "coverage": "yarn test --coverage",
    "check": "yarn lint && yarn build && yarn test"
  },
  "dependencies": {
    "@launchdarkly/js-server-sdk-common": "2.19.3",
    "crypto-js": "^4.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@jest/globals": "^30.2.0",
    "@shopify/oxygen-workers-types": "^4.2.0",
    "@types/crypto-js": "^4.1.1",
    "@types/jest": "^29.5.0",
    "eslint": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.0.0",
    "eslint-plugin-import-x": "^4.0.0",
    "eslint-plugin-jest": "^28.0.0",
    "globals": "^16.0.0",
    "jest": "^29.5.0",
    "rimraf": "^5.0.1",
    "ts-jest": "^29.1.0",
    "tsup": "^8.3.5",
    "typescript": "5.1.6",
    "typescript-eslint": "^8.0.0"
  }
}
