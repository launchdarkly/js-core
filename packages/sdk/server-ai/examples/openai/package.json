    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "eslint": "^8.45.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jest": "^27.6.3",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
