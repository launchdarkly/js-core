{
  "name": "@launchdarkly/server-sdk-ai",
  "version": "0.17.0",
  "description": "LaunchDarkly AI SDK for Server-Side JavaScript",
  "homepage": "https://github.com/launchdarkly/js-core/tree/main/packages/sdk/server-ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/launchdarkly/js-core.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup-node",
    "lint": "npx eslint . --ext .ts",
    "lint:fix": "npx eslint . --ext .ts --fix",
    "check": "yarn lint:fix && yarn lint && yarn build && yarn test",
    "test": "jest"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "launchdarkly",
    "ai",
    "llm"
  ],
  "author": "LaunchDarkly",
  "license": "Apache-2.0",
  "dependencies": {
    "mustache": "^4.2.0"
  },
  "devDependencies": {
    "@launchdarkly/js-server-sdk-common": "2.18.4",
    "@types/jest": "^29.5.3",
    "@types/mustache": "^4.2.5",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "eslint": "^8.45.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jest": "^27.6.3",
    "jest": "^29.6.1",
    "ts-jest": "^29.1.1",
    "tsup": "^8.5.1",
    "typescript": "5.1.6"
  },
  "peerDependencies": {
    "@launchdarkly/js-server-sdk-common": "2.x"
  }
}
