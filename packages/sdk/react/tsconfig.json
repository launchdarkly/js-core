{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "lib": ["es2020", "dom"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noImplicitOverride": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "stripInternal": true,
    "target": "ES2017",
    "types": ["jest", "node", "react/canary"],
    "jsx": "react",
    "paths": {
      "@launchdarkly/react-sdk": ["./src/client/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["**/*.test.ts", "dist", "node_modules", "__tests__", "examples/**"]
}
