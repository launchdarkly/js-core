{
  "name": "@launchdarkly/fastly-server-sdk",
  "version": "0.2.17",
  "description": "Fastly LaunchDarkly SDK",
  "homepage": "https://github.com/launchdarkly/js-core/tree/main/packages/sdk/fastly",
  "repository": {
    "type": "git",
    "url": "https://github.com/launchdarkly/js-core.git"
  },
  "license": "Apache-2.0",
  "keywords": [
    "launchdarkly",
    "fastly",
    "edge",
    "compute",
    "kv"
  ],
  "type": "module",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "require": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "main": "../dist/index.cjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "tsw": "yarn tsc --watch",
    "start": "rimraf dist && yarn tsw",
    "lint": "eslint .",
    "test": "npx jest --runInBand",
    "coverage": "yarn test --coverage",
    "check": "yarn lint && yarn build && yarn test"
  },
  "dependencies": {
    "@fastly/js-compute": "^3.30.1",
    "@launchdarkly/js-server-sdk-common": "2.19.3",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^29.5.14",
    "eslint": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.0.0",
    "eslint-plugin-import-x": "^4.0.0",
    "eslint-plugin-jest": "^28.0.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typedoc": "^0.27.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.0.0"
  }
}
