{
  "name": "@launchdarkly/cloudflare-server-sdk",
  "version": "2.7.25",
  "description": "Cloudflare LaunchDarkly SDK",
  "homepage": "https://github.com/launchdarkly/js-core/tree/main/packages/sdk/cloudflare",
  "repository": {
    "type": "git",
    "url": "https://github.com/launchdarkly/js-core.git"
  },
  "license": "Apache-2.0",
  "keywords": [
    "launchdarkly",
    "cloudflare",
    "edge",
    "worker"
  ],
  "type": "module",
  "exports": {
    "types": "./dist/esm/src/index.d.ts",
    "import": "./dist/esm/index.js",
    "require": "./dist/cjs/index.js"
  },
  "main": "./dist/cjs/index.js",
  "types": "./dist/esm/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "rb": "rollup -c --configPlugin typescript",
    "rbw": "yarn rb --watch",
    "build": "yarn clean && yarn rb",
    "tsw": "yarn tsc --watch",
    "start": "rimraf dist && yarn tsw",
    "lint": "eslint .",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules --no-warnings\" jest --ci --runInBand",
    "coverage": "yarn test --coverage",
    "check": "yarn lint && yarn build && yarn test"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20230321.0",
    "@launchdarkly/js-server-sdk-common-edge": "2.6.22",
    "crypto-js": "^4.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.0.0",
    "@rollup/plugin-node-resolve": "^15.2.1",
    "@rollup/plugin-terser": "^0.4.3",
    "@rollup/plugin-typescript": "^11.1.3",
    "@types/crypto-js": "^4.1.1",
    "@types/jest": "^29.5.0",
    "@types/rollup-plugin-generate-package-json": "^3.2.3",
    "eslint": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.0.0",
    "eslint-plugin-import-x": "^4.0.0",
    "eslint-plugin-jest": "^28.0.0",
    "globals": "^16.0.0",
    "jest": "^29.5.0",
    "launchdarkly-js-test-helpers": "^2.2.0",
    "miniflare": "^2.13.0",
    "rimraf": "^5.0.1",
    "rollup": "^3.29.2",
    "rollup-plugin-filesize": "^10.0.0",
    "rollup-plugin-generate-package-json": "^3.2.0",
    "ts-jest": "^29.1.0",
    "typedoc": "0.25.0",
    "typescript": "5.1.6",
    "typescript-eslint": "^8.0.0"
  }
}
