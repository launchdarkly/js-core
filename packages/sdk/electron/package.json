{
  "name": "@launchdarkly/electron-client-sdk",
  "version": "0.0.1",
  "description": "Electron LaunchDarkly SDK",
  "homepage": "https://github.com/launchdarkly/js-core/tree/main/packages/sdk/electron",
  "repository": {
    "type": "git",
    "url": "https://github.com/launchdarkly/js-core.git"
  },
  "license": "Apache-2.0",
  "keywords": [
    "launchdarkly",
    "electron",
    "feature flags",
    "feature toggles",
    "feature management"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge.d.ts",
      "import": "./dist/bridge.js",
      "require": "./dist/bridge.cjs",
      "default": "./dist/bridge.js"
    },
    "./renderer": {
      "types": "./dist/renderer.d.ts",
      "import": "./dist/renderer.js",
      "require": "./dist/renderer.cjs",
      "default": "./dist/renderer.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "lint:fix": "yarn lint --fix",
    "test": "jest"
  },
  "peerDependencies": {
    "electron": ">=34.5.6"
  },
  "dependencies": {
    "@launchdarkly/js-client-sdk-common": "workspace:^",
    "https-proxy-agent": "^7.0.6",
    "launchdarkly-eventsource": "2.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/jest": "^29.4.0",
    "electron": "^34.5.6",
    "eslint": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.0.0",
    "eslint-plugin-import-x": "^4.0.0",
    "eslint-plugin-jest": "^28.0.0",
    "globals": "^16.0.0",
    "jest": "^29.5.0",
    "launchdarkly-js-test-helpers": "^2.2.0",
    "ts-jest": "^29.0.5",
    "tsup": "^8.5.1",
    "typedoc": "0.25.0",
    "typescript": "5.1.6",
    "typescript-eslint": "^8.0.0"
  }
}
