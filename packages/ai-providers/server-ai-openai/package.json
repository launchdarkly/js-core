{
  "name": "@launchdarkly/server-sdk-ai-openai",
  "version": "0.7.7",
  "description": "LaunchDarkly AI SDK OpenAI Provider for Server-Side JavaScript",
  "homepage": "https://github.com/launchdarkly/js-core/tree/main/packages/ai-providers/server-ai-openai",
  "repository": {
    "type": "git",
    "url": "https://github.com/launchdarkly/js-core.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup-node",
    "lint": "npx eslint .",
    "lint:fix": "yarn run lint --fix",
    "check": "yarn lint && yarn build && yarn test",
    "test": "jest"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "launchdarkly",
    "ai",
    "llm",
    "openai"
  ],
  "author": "LaunchDarkly",
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@launchdarkly/js-server-sdk-common": "2.19.5",
    "@launchdarkly/server-sdk-ai": "^1.2.3",
    "@openai/agents": "^0.9.0",
    "@opentelemetry/api": "^1.9.0",
    "@traceloop/instrumentation-openai": "^0.22.0",
    "@types/jest": "^29.5.3",
    "eslint": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.0.0",
    "eslint-plugin-import-x": "^4.0.0",
    "eslint-plugin-jest": "^28.0.0",
    "globals": "^16.0.0",
    "jest": "^29.6.1",
    "openai": "^5.0.0",
    "ts-jest": "^29.1.1",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.0.0"
  },
  "peerDependencies": {
    "@launchdarkly/server-sdk-ai": "^1.1.1",
    "@openai/agents": "^0.9.0",
    "@opentelemetry/api": "^1.0.0",
    "@traceloop/instrumentation-openai": "^0.22.0",
    "openai": ">= 4 < 7"
  },
  "peerDependenciesMeta": {
    "@openai/agents": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    },
    "@traceloop/instrumentation-openai": {
      "optional": true
    }
  }
}
