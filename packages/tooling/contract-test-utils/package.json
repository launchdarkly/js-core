{
  "name": "@launchdarkly/js-contract-test-utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapter": {
      "types": "./dist/adapter.d.ts",
      "import": "./dist/adapter.js",
      "default": "./dist/adapter.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    }
  },
  "typesVersions": {
    "*": {
      "adapter": [
        "./dist/adapter.d.ts"
      ],
      "client": [
        "./dist/client.d.ts"
      ],
      "server": [
        "./dist/server.d.ts"
      ]
    }
  },
  "bin": {
    "sdk-testharness-server": "./dist/bin/sdk-testharness-server.js",
    "sts": "./dist/bin/sdk-testharness-server.js"
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.client.json && tsc -p tsconfig.server.json && tsc -p tsconfig.adapter.json",
    "build:adapter": "tsc -p tsconfig.adapter.json",
    "build:client": "tsc -p tsconfig.client.json",
    "build:server": "tsc -p tsconfig.server.json",
    "lint": "eslint . --ext .ts",
    "lint:fix": "yarn run lint --fix",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@launchdarkly/js-client-sdk-common": "workspace:^",
    "@launchdarkly/js-server-sdk-common": "workspace:^",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^18.11.9",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "eslint": "^8.45.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jest": "^27.6.3",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "typescript": "^4.9.0"
  }
}
