{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "lib": ["es6", "dom"],
    "module": "ESNext",
    "ignoreDeprecations": "6.0",
    "moduleResolution": "Bundler",
    "noImplicitOverride": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "stripInternal": true,
    "target": "ES2017",
    "types": ["jest", "node"]
  },
  "include": ["src/**/*"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "dist", "node_modules", "__tests__"]
}
